{
  "name": "wisper",
  "version": "3.0.1",
  "description": "Voice input for Linux",
  "main": "electron/main.cjs",
  "homepage": "https://github.com/jtbr/wisper",
  "type": "module",
  "scripts": {
    "copy-vad-assets": "bash scripts/copy-vad-assets.sh",
    "dev": "vite",
    "prebuild": "pnpm run copy-vad-assets",
    "build": "tsc && vite build",
    "electron": "electron . --no-sandbox",
    "electron:dev": "pnpm run copy-vad-assets && trap 'exit 0' INT TERM; concurrently --kill-others --success first 'vite' 'wait-on http://localhost:5173 && electron . --no-sandbox'",
    "package": "pnpm run build && electron-builder --linux AppImage deb rpm"
  },
  "keywords": [
    "voice",
    "dictation",
    "whisper",
    "speech-to-text"
  ],
  "author": "Justin Briggs",
  "license": "MIT",
  "devDependencies": {
    "@ricky0123/vad-web": "^0.0.30",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^9.2.1",
    "electron": "41.3.0",
    "electron-builder": "^26.8.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.wisper.voice",
    "productName": "Wisper",
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm",
        "pacman"
      ],
      "icon": "assets/icon.png",
      "category": "Utility",
      "maintainer": "Justin Briggs <jtbr@users.noreply.github.com>"
    },
    "deb": {
      "afterInstall": "scripts/postinstall.sh",
      "afterRemove": "scripts/postremove.sh",
      "depends": [
        "ydotool"
      ]
    },
    "rpm": {
      "afterInstall": "scripts/postinstall.sh",
      "afterRemove": "scripts/postremove.sh",
      "depends": [
        "ydotool"
      ]
    },
    "pacman": {
      "afterInstall": "scripts/postinstall.sh",
      "afterRemove": "scripts/postremove.sh",
      "depends": [
        "ydotool"
      ]
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/icon.png"
    ],
    "afterPack": "scripts/strip-locales.cjs"
  },
  "dependencies": {}
}
