{
  "name": "unhush",
  "version": "3.0.4",
  "description": "Voice input for Linux",
  "main": "electron/main.cjs",
  "homepage": "https://unhush.propriaworks.com",
  "type": "module",
  "scripts": {
    "copy-vad-assets": "bash scripts/copy-vad-assets.sh",
    "dev": "vite",
    "prebuild": "pnpm run copy-vad-assets",
    "build": "tsc && vite build",
    "electron": "electron . --no-sandbox",
    "electron:dev": "pnpm run copy-vad-assets && trap 'exit 0' INT TERM; concurrently --kill-others --success first 'vite' 'wait-on http://localhost:5173 && electron . --no-sandbox'",
    "package": "pnpm run build && electron-builder --linux AppImage deb rpm",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "voice",
    "dictation",
    "whisper",
    "speech-to-text"
  ],
  "author": "Justin Briggs",
  "license": "MIT",
  "devDependencies": {
    "@ricky0123/vad-web": "^0.0.30",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "electron": "43.0.0",
    "electron-builder": "^26.15.3",
    "esbuild": "0.28.1",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9",
    "wait-on": "^9.0.10"
  },
  "desktopName": "com.propriaworks.unhush",
  "build": {
    "appId": "com.propriaworks.unhush",
    "productName": "Unhush",
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm",
        "pacman"
      ],
      "icon": "assets/icon.png",
      "category": "Utility",
      "maintainer": "Justin Briggs <jtbr@users.noreply.github.com>",
      "syncDesktopName": true
    },
    "deb": {
      "afterInstall": "scripts/postinstall.sh",
      "afterRemove": "scripts/postremove.sh",
      "depends": [
        "ydotool"
      ],
      "recommends": [
        "x11-utils"
      ]
    },
    "rpm": {
      "afterInstall": "scripts/postinstall.sh",
      "afterRemove": "scripts/postremove.sh",
      "depends": [
        "ydotool"
      ]
    },
    "pacman": {
      "afterInstall": "scripts/postinstall.sh",
      "afterRemove": "scripts/postremove.sh",
      "depends": [
        "ydotool"
      ]
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/icon.png",
      "assets/icon-warning.png"
    ],
    "afterPack": "scripts/strip-locales.cjs"
  }
}
